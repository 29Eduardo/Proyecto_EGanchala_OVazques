[mysqld]
server-id = 2
relay-log = mysql-relay-bin
# NOTA: read_only/super_read_only quedaron desactivados a propósito porque
# este nodo ahora también acepta escrituras (replicación bidireccional).
# Si en algún momento quieren volver a un esquema maestro-esclavo clásico
# (solo lectura en este nodo), descomenten estas dos líneas:
# read_only = 1
# super_read_only = 1
gtid_mode = ON
enforce_gtid_consistency = ON
log-bin = mysql-bin
log_slave_updates = 1
default_authentication_plugin = mysql_native_password
auto_increment_increment = 2
auto_increment_offset = 2
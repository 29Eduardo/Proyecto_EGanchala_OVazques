[mysqld]
# Debe ser distinto al server-id del maestro
server-id = 2

relay-log = mysql-relay-bin

# El esclavo solo debe recibir escrituras vía replicación, no directamente
read_only = 1
super_read_only = 1

# Debe coincidir con la configuración de GTID del maestro
gtid_mode = ON
enforce_gtid_consistency = ON

# Con log-bin + log_slave_updates el esclavo también registra lo replicado;
# útil si más adelante quieren encadenar una tercera réplica o monitoreo
log-bin = mysql-bin
log_slave_updates = 1

default_authentication_plugin = mysql_native_password

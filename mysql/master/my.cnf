[mysqld]
# Identificador único del servidor — debe ser distinto en cada nodo de la replicación
server-id = 1

# Habilita el binary log; es lo que le permite al maestro transmitir cambios al esclavo
log-bin = mysql-bin
binlog_format = ROW

# Solo registrar cambios de la base de datos de la aplicación
binlog_do_db = taskdb

# Replicación basada en GTID: más robusta y fácil de configurar que usar
# manualmente el archivo y la posición del binlog
gtid_mode = ON
enforce_gtid_consistency = ON

# Compatibilidad de autenticación con clientes/drivers como PyMySQL
default_authentication_plugin = mysql_native_password
